DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DATABASE_URL=mysql+pymysql://root:root1234@127.0.0.1:3306/gaosi_tutor?charset=utf8mb4

# RAG（家庭笔记向量库，本地 Embedding，无需额外 API Key）
RAG_CHROMA_PATH=data/chroma
RAG_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
RAG_TOP_K=3

# Hugging Face 模型下载（国内推荐镜像；官方源改为 https://huggingface.co）
HF_ENDPOINT=https://hf-mirror.com
# 镜像下建议关闭 Xet，避免 SSL/元数据失败（官方源也可设为 0）
HF_HUB_DISABLE_XET=1

# Rerank（docs/rag-rerank-exercise.md 练习 7）
# local=本机 Cross-Encoder | zhipu=智谱 API | off=跳过精排（hybrid 原序）
RERANK_PROVIDER=local
RAG_RERANK_MODEL=Xenova/ms-marco-MiniLM-L-6-v2
# 智谱（仅 RERANK_PROVIDER=zhipu 时需要）
ZHIPU_API_KEY=
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_RERANK_MODEL=rerank
